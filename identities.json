{
  "version": "1.0",
  "name": "SawftLaunch Identity API",
  "description": "A read-only design-identity data source. Fetch this file to pull curated design directions: color palettes and font pairings. Free, static, no auth.",
  "endpoint_note": "GET this file's URL to receive all directions as JSON.",
  "directions": [
    {
      "id": "editorial",
      "name": "Editorial",
      "description": "Magazine-grade. A characterful serif doing the talking, restrained body text, warm paper tones. Feels considered, literary, grown-up.",
      "fonts": {
        "display": { "name": "Fraunces", "weight": 600 },
        "body": { "name": "Newsreader", "weight": 400 },
        "google_fonts_url": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Newsreader:opsz,wght@6..72,400;6..72,500&display=swap"
      },
      "palettes": [
        { "bg": "#f6f1e7", "ink": "#1d1b18", "accent": "#b5482e", "accent2": "#7d8466", "soft": "#cdbfa6" },
        { "bg": "#efe9dd", "ink": "#2a2520", "accent": "#9c5a3c", "accent2": "#3f5e52", "soft": "#d8c8ad" }
      ]
    },
    {
